generator client {
  provider      = "prisma-client-js"
  // Multi-platform binary targets — "native" covers founder's Mac (darwin-arm64);
  // "linux-arm64-openssl-3.0.x" covers Cowork sandbox so parity-runner can execute.
  // Required for SOL-990 sprint workflow where corpus regen runs from sandbox.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SourceRepository {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  author      String
  sourceUrl   String   @unique
  githubUrl   String?
  description String
  rating      Int      @default(0)
  lastSyncedAt DateTime?
  syncStatus  String   @default("PENDING") // PENDING | SYNCING | SYNCED | FAILED
  syncError   String?
  skills      Skill[]
  syncJobs    SyncJob[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id                 String   @id @default(cuid())
  sourceRepositoryId String
  sourceRepository   SourceRepository @relation(fields: [sourceRepositoryId], references: [id], onDelete: Cascade)
  name               String
  slug               String   @unique
  description        String
  longDescription    String?
  rawContent         String?
  embeddingText      String?
  imageUrl           String?
  authorName         String?
  authorUrl          String?
  repoUrl            String?
  rating             Int      @default(0)
  confidenceBase     Float    @default(0.5)
  lastSyncedAt       DateTime?
  categories         SkillCategory[]
  tags               SkillTag[]
  capabilities       SkillCapability[]
  relationsFrom      SkillRelation[] @relation("FromSkill")
  relationsTo        SkillRelation[] @relation("ToSkill")
  queryMatches       QueryMatch[]
  uses               SkillUse[] // SOL-1018: dogfood click-through events
  curationStatus     String   @default("unreviewed") // unreviewed | favorited | hidden
  notes              String?
  installedAt        DateTime?
  installedPath      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([sourceRepositoryId])
  @@index([name])
  @@index([curationStatus])
  @@index([installedAt])
}

model SkillCategory {
  id       String @id @default(cuid())
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  category String

  @@unique([skillId, category])
  @@index([category])
}

model SkillTag {
  id      String @id @default(cuid())
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag     String

  @@unique([skillId, tag])
  @@index([tag])
}

model SkillCapability {
  id         String  @id @default(cuid())
  skillId    String
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  capability String
  inputType  String?
  outputType String?

  @@index([skillId])
}

model SkillRelation {
  id           String @id @default(cuid())
  fromSkillId  String
  toSkillId    String
  relationType String // "similar" | "extends" | "depends_on" | "alternative"
  fromSkill    Skill  @relation("FromSkill", fields: [fromSkillId], references: [id], onDelete: Cascade)
  toSkill      Skill  @relation("ToSkill", fields: [toSkillId], references: [id], onDelete: Cascade)

  @@unique([fromSkillId, toSkillId, relationType])
}

model SyncJob {
  id                 String   @id @default(cuid())
  sourceRepositoryId String?
  sourceRepository   SourceRepository? @relation(fields: [sourceRepositoryId], references: [id])
  status             String   @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  details            String?
  startedAt          DateTime @default(now())
  completedAt        DateTime?
}

model UserQuery {
  id            String   @id @default(cuid())
  rawInput      String
  queryType     String   // single_task | multi_task | plan | deliverable
  scorerVersion String?  // SOL-1018: git SHA of scorer at query time, for replay
  corpusSha     String?  // SOL-1018: SHA of corpus used (skill set version)
  tasks         QueryTask[]
  uses          SkillUse[]
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model QueryTask {
  id           String  @id @default(cuid())
  userQueryId  String
  userQuery    UserQuery @relation(fields: [userQueryId], references: [id], onDelete: Cascade)
  taskText     String
  position     Int
  parentTaskId String?
  matches      QueryMatch[]
}

model QueryMatch {
  id            String @id @default(cuid())
  queryTaskId   String
  queryTask     QueryTask @relation(fields: [queryTaskId], references: [id], onDelete: Cascade)
  skillId       String
  skill         Skill  @relation(fields: [skillId], references: [id])
  rank          Int    @default(0) // SOL-1018: 1-indexed rank within this task's match list
  score         Float
  lexicalScore  Float  @default(0)
  semanticScore Float  @default(0)
  ruleScore     Float  @default(0)
  rationale     String?
  uses          SkillUse[] // SOL-1018: back-ref to which click-throughs targeted this match

  @@index([queryTaskId, rank])
}

// SOL-1018: dogfood instrumentation. Captures click-through events (install,
// view, copy, etc.) so we can compute click-through rates per rank position.
// Each SkillUse links to:
//   - userQuery: the originating query (for grouping and CTR analysis)
//   - queryMatch: the specific match-result the user acted on (gives us rank
//     + scoring breakdown + skill metadata)
// If a use happens outside a query context (e.g., direct browse), userQueryId
// is null and queryMatchId is null; we still record the skill via skillId.
model SkillUse {
  id           String      @id @default(cuid())
  userQueryId  String?
  userQuery    UserQuery?  @relation(fields: [userQueryId], references: [id], onDelete: SetNull)
  queryMatchId String?
  queryMatch   QueryMatch? @relation(fields: [queryMatchId], references: [id], onDelete: SetNull)
  skillId      String
  skill        Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)
  useType      String      // install | view | copy | uninstall
  // SOL-1018: denormalized rank when this use was triggered from a query.
  // null when the use happened outside query context (direct browse).
  // Captured at use-time so report generator doesn't need to join QueryMatch.
  rank         Int?
  createdAt    DateTime    @default(now())

  @@index([skillId])
  @@index([userQueryId])
  @@index([createdAt])
  @@index([useType])
  @@index([rank])
}
